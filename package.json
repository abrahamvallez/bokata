{
  "name": "bokata-agent",
  "version": "1.0.0",
  "description": "LangChain/LangGraph TypeScript implementation of Bokata Slicer - Multi-agent system for feature decomposition using the Hamburger Method",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bokata": "./dist/cli/bokata-cli.js",
    "bokata-agent": "./dist/cli/bokata-cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/bokata-cli.js",
    "dev": "ts-node src/cli/bokata-cli.ts",
    "dev:example": "ts-node",
    "bokata": "ts-node src/cli/bokata-cli.ts project",
    "bokata-feature": "ts-node src/cli/bokata-cli.ts feature",
    "bokata-paths": "ts-node src/cli/bokata-cli.ts paths",
    "bokata-matrix": "ts-node src/cli/bokata-cli.ts matrix",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "langchain",
    "langgraph",
    "agents",
    "feature-slicing",
    "hamburger-method",
    "typescript"
  ],
  "author": "Abraham Vallez",
  "license": "GPL-3.0",
  "dependencies": {
    "@langchain/anthropic": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "commander": "^14.0.2",
    "dotenv": "^16.3.1",
    "gray-matter": "^4.0.3",
    "langchain": "^0.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
